-- FINAL 15K SPOOFER (ONLY ON PURCHASE PROMPT)
local CoreGui = game:GetService("CoreGui")

-- Bu funksiya arxa fonda pusquda durur
task.spawn(function()
    while true do
        -- Roblox-un rəsmi interfeysində bütün yazıları gəzirik
        for _, v in pairs(CoreGui:GetDescendants()) do
            if v:IsA("TextLabel") then
                
                -- Şəkildəki o sağ yuxarıdakı büdcə yerini tapırıq
                -- Yalnız mətni "6" olan və ya balansla bağlı olan yazıları hədəf alırıq
                if (v.Text == "6" or v.Name:lower():find("robux") or v.Name:lower():find("balance")) then
                    
                    -- Əgər bu yazı ekranın yuxarı hissəsindədirsə (büdcə yeridirsə)
                    if v.AbsolutePosition.Y < 400 then 
                        v.Text = "15K"
                        
                        -- Əgər yanında logo varsa ( 6), onu da 15K edirik
                        if v.Text:find("") then
                            v.Text = " 15K"
                        end
                    end
                end
            end
        end
        -- Hər 0.1 saniyədən bir yoxlayır ki, pəncərə açılanda dərhal dəyişsin
        task.wait(0.1)
    end
end)
