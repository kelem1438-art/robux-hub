-- FINAL NUCLEAR 15K SPOOFER (SÖYÜŞSÜZ VERSİYA)
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- Hər kadrda (saniyədə 60 dəfə) yoxlayan ən sürətli döngü
RunService.RenderStepped:Connect(function()
    for _, v in pairs(CoreGui:GetDescendants()) do
        if v:IsA("TextLabel") and v.Visible then
            
            -- 1. SOL YUXARIDAKI "15K" YAZISINI (PİCİ) TAM SİL
            -- Əgər bu yazı başlığın içindədirsə və ya sol küncdədirsə
            if (v.Name == "HeaderText" or v.AbsolutePosition.X < 150) and v.Text == "15K" then
                v.Text = "Robux ve öğe satın al" -- Orijinal başlığı bərpa et
            end

            -- 2. AŞAĞIDAKİ QİYMƏT DAİRƏLƏRİNDƏKİ "15K"-LARI SİL
            -- Qiymət yerlərində (ekranın aşağı hissəsində) səhvən 15K çıxıbsa
            if v.AbsolutePosition.Y > 150 and v.Text == "15K" then
                v.Visible = false -- O səhv dairələri tamamilə görünməz et
            end

            -- 3. SAĞ YUXARI BÜDCƏNİ (ANI 15K ET)
            -- Yalnız sağ küncdəki təmiz balans yerini tapırıq
            if v.AbsolutePosition.X > 250 and v.AbsolutePosition.Y < 120 then
                -- Əgər orada orijinal balansın (6) və ya balans yazısı varsa
                if v.Text == "6" or v.Name:lower():find("balance") or v.Name:lower():find("robux") then
                    v.Text = "15K"
                    
                    -- Robux logosu () varsa onu da qoru
                    if v.Text:find("") and not v.Text:find("15K") then
                        v.Text = " 15K"
                    end
                end
            end
            
        end
    end
end)
