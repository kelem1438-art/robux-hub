-- EN SADE VE EN SURATLI 15K (GECIKMESIZ)
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- Her kadrda (saniyede 60 defe) yoxlayir
RunService.RenderStepped:Connect(function()
    for _, v in pairs(CoreGui:GetDescendants()) do
        if v:IsA("TextLabel") and v.Visible then
            
            -- 1. HARADA "6" GORSE 15K ET (BUTUN BUDCE YERLERI UCUN)
            if v.Text == "6" or v.Text == " 6" or v.Text == "R$ 6" then
                v.Text = v.Text:gsub("6", "15K")
            end

            -- 2. SOLDAKI SEHV "15K" YAZISINI TEMIZLE (BASLIQ)
            -- Eger sol yuxari kuncde (X < 150) "15K" yazilibsa, onu orijinal basliga cevir
            if v.AbsolutePosition.X < 150 and v.Text == "15K" then
                v.Text = "Robux ve öğe satın al"
            end
            
            -- 3. EGER BUDCE ADI ILE BAGLIDIRSA VE 15K DEYILSE
            if (v.Name:lower():find("robux") or v.Name:lower():find("balance")) and not v.Text:find("15K") then
                -- Qiymetlere (4.199 ve s.) toxunmamaq ucun filtr
                if not v.Text:find("%.") and not v.Text:find(",") then
                    v.Text = "15K"
                end
            end

        end
    end
end)
