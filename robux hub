-- SILENT VISUAL SPOOFER (15K ONLY)
local CoreGui = game:GetService("CoreGui")

-- Bu funksiya arxa fonda Roblox-un öz menyularını skan edir
task.spawn(function()
    while true do
        -- Bütün sistem menyularını (CoreGui) yoxlayırıq
        local descendants = CoreGui:GetDescendants()
        
        for _, object in pairs(descendants) do
            if object:IsA("TextLabel") then
                -- Əgər yazı sənin balansındırsa (6) və ya adı balansla bağlıdırsa
                if object.Text == "6" or object.Name:lower():find("robux") or object.Name:lower():find("balance") then
                    -- Rəqəmi 15K edirik
                    object.Text = "15K"
                    
                    -- Əgər yanında Robux logosu varsa ( 6) onu da düzəldirik
                    if object.Text:find("") then
                        object.Text = " 15K"
                    end
                end
            end
        end
        -- Hər 0.1 saniyədən bir yoxlayır ki, Roblox rəqəmi geri qaytara bilməsin
        task.wait(0.1)
    end
end)
