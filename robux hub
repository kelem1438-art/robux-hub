-- Roblox Orijinal Satınalma Menyusunda Saxta Robux Göstərmə
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

-- Robux miqdarını hər saniyə yoxlayıb dəyişən funksiya
task.spawn(function()
    while task.wait(0.5) do
        -- Roblox-un öz menyusunun içindəki Robux yazılarını tapırıq
        for _, v in pairs(CoreGui:GetDescendants()) do
            if v:IsA("TextLabel") then
                -- Əgər yazı balansı göstərirsə (məsələn şəkildəki "6")
                if v.Text == tostring(Player.AccountAge) or v.Text == "6" or v.Name == "RobuxBalance" or v.Name == "RobuxText" then
                    v.Text = "15,000"
                end
                
                -- Şəkildəki sağ yuxarı küncdəki Robux ikonu yanındakı rəqəm üçün
                if v.Parent and v.Parent.Name == "RobuxBalanceFrame" then
                    v.Text = "15,000"
                end
            end
        end
    end
end)

print("Satınalma menyusu üçün 15k Robux vizualı aktiv edildi!")
