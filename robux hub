-- ONLY BUDGET = 15K (NO OTHER CHANGES)
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

RunService.RenderStepped:Connect(function()
    for _, v in pairs(CoreGui:GetDescendants()) do
        if v:IsA("TextLabel") and v.Visible then
            
            -- YALNIZ SAĞ YUXARI BÜDCƏ
            if v.AbsolutePosition.X > 250 and v.AbsolutePosition.Y < 100 then
                
                -- Əgər orda ədəd varsa onu 15K et
                if tonumber(v.Text) or v.Text:find("6") or v.Name:lower():find("balance") then
                    v.Text = "15K"
                end

            end

        end
    end
end)
