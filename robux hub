-- FINAL 15K OVERRIDE (NO DELAY + NO BUGS)
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- Əvvəlki bütün səhv yazıları (dairədəki 15K-ları) tamamilə sıfırlayırıq
for _, v in pairs(CoreGui:GetDescendants()) do
    if v:IsA("TextLabel") and v.Text == "15K" then
        v.Text = "" -- Köhnələri silirik ki, təzədən başlayaq
    end
end

-- Saniyədə 60-100 dəfə yoxlayan ən aqressiv döngü
RunService.Heartbeat:Connect(function()
    for _, label in pairs(CoreGui:GetDescendants()) do
        if label:IsA("TextLabel") and label.Visible then
            
            -- 1. SAĞ YUXARI BÜDCƏNİ TUTURUQ (ANI 15K ET)
            -- Əgər mətndə "6" varsa və ya büdcə yeridirsə (X > 200 küncü)
            if label.AbsolutePosition.X > 200 and (label.Text == "6" or label.Text == " 6" or label.Name:lower():find("balance")) then
                label.Text = "15K"
                -- Logo varsa onu da bərpa edirik
                if label.Text:find("") then label.Text = " 15K" end
            end

            -- 2. SOL YUXARIDAKI O SEHV "15K" YAZISINI SİLİRİK
            -- Əgər sol küncdə (X < 150) səhvən 15K yazılıbsa, onu orijinal başlığa qaytar
            if label.AbsolutePosition.X < 150 and label.Text == "15K" then
                label.Text = "Robux ve öğe satın al"
            end
            
            -- 3. AŞAĞIDAKİ QİYMƏT DAİRƏLƏRİNDƏKİ SƏHV 15K-LARI SİL
            -- Qiymət yerlərində (Y > 150) səhvən 15K çıxıbsa, onları gizlədirik
            if label.AbsolutePosition.Y > 150 and label.Text == "15K" then
                label.Visible = false
            end
        end
    end
end)
