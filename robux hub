-- ONLY TOP RIGHT BALANCE SPOOFER (15K)
local CoreGui = game:GetService("CoreGui")

task.spawn(function()
    while true do
        -- Bütün menyu elementlərini gəzirik
        for _, v in pairs(CoreGui:GetDescendants()) do
            -- Yalnız sağ yuxarıdakı Balans (Robux) yerini hədəf alırıq
            if v:IsA("TextLabel") and (v.Name == "RobuxBalanceText" or v.Name == "RobuxText" or v.Name == "BalanceText") then
                -- Əgər orada sənin balansın (6) yazılıbsa, onu 15K edirik
                if v.Text == "6" or v.Text:find("6") then
                    v.Text = "15K"
                end
                
                -- Əgər yanında logo varsa ( 6), onu da 15K edirik
                if v.Text:find("") then
                    v.Text = " 15K"
                end
            end
        end
        task.wait(0.1) -- Hər 0.1 saniyədən bir yoxlayır
    end
end)
