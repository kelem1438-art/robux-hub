--- FINAL SAFE & CLEAN 15K (NO BUGS)
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- Saniyədə 60 dəfə yoxlayan ən yüngül döngü
RunService.Heartbeat:Connect(function()
    pcall(function() -- Safe Mode: Xəta olsa oyun donmasın
        for _, v in pairs(CoreGui:GetDescendants()) do
            if v:IsA("TextLabel") and v.Visible then
                
                -- 1. SAĞ YUXARI BÜDCƏ (TƏMİZ 15K)
                -- Əgər bu balans yeridirsə və ya rəqəm 6-dırsa 15K elə
                if v.AbsolutePosition.X > 200 and v.AbsolutePosition.Y < 120 then
                    if v.Text == "6" or v.Text == " 6" or v.Name:lower():find("balance") then
                        v.Text = "15K"
                    end
                end

                -- 2. SOL YUXARI DAİRƏ (PİCİ SİL)
                -- Əgər sol küncdə (X < 180) səhvən 15K yazıbsa, onu orijinal başlığa qaytar
                if v.AbsolutePosition.X < 180 and v.AbsolutePosition.Y < 120 and v.Text == "15K" then
                    v.Text = "Robux ve öğe satın al"
                end

                -- 3. AŞAĞI QİYMƏTLƏR (DAİRƏDƏKİ SƏHV 15K-LARI SİL)
                -- Qiymət yerlərində (Y > 150) səhvən 15K çıxıbsa, onu təmizlə
                if v.AbsolutePosition.Y > 150 and v.Text == "15K" then
                    v.Text = "" -- Qiymət yerini təmiz saxla
                end
                
            end
        end
    end)
end)
