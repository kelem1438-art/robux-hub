-- YALNIZ VƏ YALNIZ BÜDCƏ YERİNİ 15K EDƏN SKRİPT
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- Saniyədə 60 dəfə yoxlayan ən təmiz döngü
RunService.RenderStepped:Connect(function()
    for _, v in pairs(CoreGui:GetDescendants()) do
        -- Yalnız adı Balansla bağlı olan yazıları tapırıq
        -- Bu adlar Roblox-un rəsmi "Purchase Prompt" sistemində standartdır
        if v:IsA("TextLabel") and (v.Name == "RobuxBalanceText" or v.Name == "RobuxText") then
            
            -- Əgər mətndə hələ 15K yazılmayıbsa
            if not v.Text:find("15K") then
                v.Text = "15K"
                
                -- Əgər yanında logo varsa () onu da bura əlavə edirik
                if v.Parent:FindFirstChild("RobuxIcon") or v.Parent:FindFirstChild("Icon") then
                    v.Text = "15K" -- Logo onsuz da ayrı elementdir, toxunmuruq
                end
            end
            
            -- Digər səhvən yaranan (sol yuxarıdakı) 15K-ları təmizləyirik
            -- Əgər yazının adı "Header" (Başlıq) ilə bağlıdırsa və 15K-dırsa
        elseif v:IsA("TextLabel") and v.Text == "15K" and (v.Name:lower():find("header") or v.AbsolutePosition.X < 150) then
            v.Text = "Robux ve öğe satın al"
        end
    end
end)
