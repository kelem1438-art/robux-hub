-- YALNIZ SAĞ YUXARI BÜDCƏNİ 15K EDƏN SKRİPT
local CoreGui = game:GetService("CoreGui")

task.spawn(function()
    while true do
        -- Bütün sistem menyularını skan edirik
        for _, v in pairs(CoreGui:GetDescendants()) do
            -- Yalnız yazı elementləri üçün
            if v:IsA("TextLabel") then
                
                -- 1. Əgər yazının adı birbaşa balansla bağlıdırsa (Ən dəqiq yol)
                if v.Name == "RobuxBalanceText" or v.Name == "RobuxText" or v.Name == "AmountText" then
                    v.Text = "15K"
                end
                
                -- 2. Əgər yazının içində həm Robux logosu (), həm də 6 rəqəmi varsa
                if v.Text:find("") and v.Text:find("6") then
                    v.Text = " 15K"
                end

                -- 3. Əgər yazı ekranın sağ yuxarı hissəsindədirsə (Şəkildəki yer)
                -- (Bu, digər qiymət yazıları ilə qarışmaması üçün filtrdir)
                if v.AbsolutePosition.Y < 200 and v.AbsolutePosition.X > 200 then
                    if v.Text == "6" then
                        v.Text = "15K"
                    end
                end
            end
        end
        task.wait(0.1) -- Sürətli yoxlama
    end
end)
