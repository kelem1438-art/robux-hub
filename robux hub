-- BEYAQKI ISLEYEN KOD (SOL YUXARI TAM SILINIB)
local CoreGui = game:GetService("CoreGui")

task.spawn(function()
    while true do
        for _, v in pairs(CoreGui:GetDescendants()) do
            if v:IsA("TextLabel") then
                
                -- 1. SAĞ YUXARIDAKI BALANSI 15K ET (BEYAQKI KIMI)
                -- Ekranın sağ tərəfindəki (X > 200) balans yerini tapırıq
                if v.AbsolutePosition.X > 200 and (v.Text == "6" or v.Name:lower():find("balance") or v.Name:lower():find("robux")) then
                    v.Text = "15K"
                    
                    -- Logo () varsa onu da 15K edirik
                    if v.Text:find("") then
                        v.Text = " 15K"
                    end
                end

                -- 2. SOL YUXARIDAKI O 15K YAZISINI SİL (TEMİZLƏ)
                -- Əgər sol küncdə (X < 200) səhvən 15K yazıbsa, onu orijinal başlığa qaytar
                if v.AbsolutePosition.X < 200 and v.Text == "15K" then
                    v.Text = "Robux ve öğe satın al"
                end
                
            end
        end
        task.wait(0.01) -- Gecikmə olmaması üçün çox sürətli yoxlayır
    end
end)
