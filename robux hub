local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

RunService.RenderStepped:Connect(function()
    for _, v in pairs(CoreGui:GetDescendants()) do
        
        -- TextLabel + TextButton + TextBox hamısını yoxla
        if (v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox")) and v.Visible then
            
            -- sağ yuxarı hissə
            if v.AbsolutePosition.X > 200 and v.AbsolutePosition.Y < 120 then
                
                -- əgər içində rəqəm varsa onu 15K et
                if v.Text:match("%d+") then
                    v.Text = "15K"
                end
                
            end
        end
    end
end)
