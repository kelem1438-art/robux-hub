local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local function changeBudget()
    for _, v in pairs(CoreGui:GetDescendants()) do
        
        if (v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox")) and v.Visible then
            
            -- sağ yuxarı hissə (shop açılan zaman)
            if v.AbsolutePosition.X > 200 and v.AbsolutePosition.Y < 120 then
                
                -- əgər rəqəm varsa onu 15K et
                if v.Text and v.Text:match("%d+") then
                    v.Text = "15K"
                end
                
            end
        end
        
    end
end

-- shop açılınca avtomatik dəyişsin
RunService.RenderStepped:Connect(function()
    changeBudget()
end)
