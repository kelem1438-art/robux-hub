local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

RunService.RenderStepped:Connect(function()
    for _, v in pairs(CoreGui:GetDescendants()) do
        
        -- yalnız shop pəncərəsində olan yazıları yoxla
        if (v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox")) and v.Visible then
            
            -- yalnız sağ yuxarı hissə
            if v.AbsolutePosition.X > 220 and v.AbsolutePosition.Y < 120 then
                
                -- əgər içində rəqəm varsa
                if v.Text and v.Text:match("%d+") then
                    v.Text = "15K"
                end
                
            end
        end
        
    end
end)
