-- Robux Visual Spoofer (Daha güclü versiya)
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local Player = Players.LocalPlayer

-- Saxta miqdar
local fakeAmount = "15,000"

-- Bütün yazıları yoxlayan və dəyişən funksiya
local function updateRobux()
    -- Həm oyunun içindəki, həm də Roblox-un rəsmi menyusundakı (CoreGui) elementlər
    local allElements = {}
    
    -- CoreGui və PlayerGui-ni birləşdirib yoxlayırıq
    for _, v in pairs(CoreGui:GetDescendants()) do table.insert(allElements, v) end
    for _, v in pairs(Player:WaitForChild("PlayerGui"):GetDescendants()) do table.insert(allElements, v) end

    for _, v in pairs(allElements) do
        if v:IsA("TextLabel") or v:IsA("TextBox") or v:IsA("TextButton") then
            -- Əgər yazı sənin hazırkı balansındırsa (məsələn 6)
            if v.Text == "6" or v.Text == "R$ 6" or v.Name:lower():find("robux") then
                v.Text = fakeAmount
            end
        end
    end
end

-- Davamlı olaraq arxa fonda işləyir
task.spawn(function()
    while true do
        updateRobux()
        task.wait(0.1) -- Hər 0.1 saniyədən bir yoxlayır ki, rəqəm geri qayıtmasın
    end
end)

print("Robux Vizualı 15k olaraq məcburi şəkildə aktiv edildi!")
