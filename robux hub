-- EN AMANSIZ 15K (ANCAQ BALANS ÜÇÜN)
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

-- Saniyədə 60-100 dəfə yoxlayan döngü
RunService.Heartbeat:Connect(function()
    for _, v in pairs(CoreGui:GetDescendants()) do
        if v:IsA("TextLabel") then
            
            -- 1. ANCAQ BÜDCƏNİ (6) 15K ET
            -- Qiymətlərə (4.199 və s.) toxunmamaq üçün nöqtə olmayanları seçirik
            if v.Text == "6" or v.Text == " 6" or v.Text == "R$ 6" then
                v.Text = "15K"
            end

            -- 2. SOL YUXARIDAKI O SEHV "15K" YAZISINI SİL
            -- Əgər sol küncdə (X < 150) səhvən 15K yazıbsa, onu başlıqla əvəz et
            if v.AbsolutePosition.X < 150 and v.Text == "15K" then
                v.Text = "Robux ve öğe satın al"
            end

            -- 3. ƏGƏR QİYMƏTLƏR SƏHVƏN 15K OLUB SA, ONLARI GİZLƏ
            -- (Dairəyə aldığın o aşağıdakı yerlər üçün)
            if v.AbsolutePosition.Y > 150 and v.Text == "15K" then
                v.Visible = false
            end
            
        end
    end
end)
